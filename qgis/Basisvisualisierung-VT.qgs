                          <Option type="QString" value="CASE WHEN @vector_tile_zoom > 12 AND @vector_tile_zoom &lt;= 12.4 THEN scale_linear(@vector_tile_zoom,12,12.4,0,0.9) * 0.264583 WHEN @vector_tile_zoom > 12.4 AND @vector_tile_zoom &lt;= 12.6 THEN scale_linear(@vector_tile_zoom,12.4,12.6,0.9,1.5) * 0.264583 WHEN @vector_tile_zoom > 12.6 AND @vector_tile_zoom &lt;= 13 THEN scale_linear(@vector_tile_zoom,12.6,13,1.5,2.7) * 0.264583 WHEN @vector_tile_zoom > 13 AND @vector_tile_zoom &lt;= 14 THEN scale_linear(@vector_tile_zoom,13,14,2.7,3.5) * 0.264583 WHEN @vector_tile_zoom > 14 AND @vector_tile_zoom &lt;= 16 THEN scale_linear(@vector_tile_zoom,14,16,3.5,13.4) * 0.264583 WHEN @vector_tile_zoom > 16 AND @vector_tile_zoom &lt;= 18 THEN scale_linear(@vector_tile_zoom,16,18,13.4,15.5) * 0.264583 WHEN @vector_tile_zoom > 18 THEN 4.10104 END" name="expression"/>
                          <Option type="int" value="3" name="type"/>
                        </Option>
                      </Option>
