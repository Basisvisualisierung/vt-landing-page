                          <Option type="QString" name="expression" value="CASE WHEN @vector_tile_zoom > 13 AND @vector_tile_zoom &lt;= 13.5 THEN scale_linear(@vector_tile_zoom,13,13.5,3,4.5) * 0.264583 WHEN @vector_tile_zoom > 13.5 AND @vector_tile_zoom &lt;= 14 THEN scale_linear(@vector_tile_zoom,13.5,14,4.5,6) * 0.264583 WHEN @vector_tile_zoom > 14 AND @vector_tile_zoom &lt;= 14.5 THEN scale_linear(@vector_tile_zoom,14,14.5,6,8) * 0.264583 WHEN @vector_tile_zoom > 14.5 AND @vector_tile_zoom &lt;= 14.8 THEN scale_linear(@vector_tile_zoom,14.5,14.8,8,11) * 0.264583 WHEN @vector_tile_zoom > 14.8 THEN 2.91042 END"/>
